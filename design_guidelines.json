    "typography": {
      "fontFamily": {
        "heading": "Manrope-Bold",
        "body": "Inter-Regular",
        "mono": "JetBrainsMono-Regular"
      },
      "fontSize": {
        "xs": 12,
        "sm": 14,
        "base": 16,
        "lg": 18,
        "xl": 20,
        "2xl": 24,
        "3xl": 30,
        "4xl": 36
      },
      "lineHeight": {
        "none": 1,
        "tight": 1.25,
        "snug": 1.375,
        "normal": 1.5,
        "relaxed": 1.625,
        "loose": 2
      },
      "letterSpacing": {
        "tighter": -0.8,
        "tight": -0.4,
        "normal": 0,
        "wide": 0.4,
        "wider": 0.8,
        "widest": 1.6
      }
    },
    "spacing": {
      "0": 0,
      "1": 4,
      "2": 8,
      "3": 12,
      "4": 16,
      "5": 20,
      "6": 24,
      "8": 32,
      "10": 40,
      "12": 48,
      "16": 64,
      "20": 80,
      "24": 96
    },
    "borderRadius": {
      "none": 0,
      "sm": 2,
      "DEFAULT": 4,
      "md": 6,
      "lg": 8,
      "xl": 12,
      "2xl": 16,
      "3xl": 24,
      "full": 9999
    },
    "shadows": {
      "sm": {
        "shadowColor": "#000",
        "shadowOffset": { "width": 0, "height": 1 },
        "shadowOpacity": 0.05,
        "shadowRadius": 2,
        "elevation": 2
      },
      "DEFAULT": {
        "shadowColor": "#000",
        "shadowOffset": { "width": 0, "height": 1 },
        "shadowOpacity": 0.1,
        "shadowRadius": 3,
        "elevation": 3
      },
      "md": {
        "shadowColor": "#000",
        "shadowOffset": { "width": 0, "height": 4 },
        "shadowOpacity": 0.1,
        "shadowRadius": 6,
        "elevation": 5
      },
      "lg": {
        "shadowColor": "#000",
        "shadowOffset": { "width": 0, "height": 10 },
        "shadowOpacity": 0.1,
        "shadowRadius": 15,
        "elevation": 10
      }
    }
  },
  "layout_strategies": {
    "auth_screen": {
      "layout": "Centered Column",
      "alignment": "center",
      "spacing": "relaxed",
      "components": [
        "Logo (Top, Large)",
        "Title (H1, Center)",
        "Input Group (Email, Password)",
        "Button (Primary, Full Width)",
        "Link (Forgot Password)",
        "Footer (Terms)"
      ]
    },
    "dashboard": {
      "layout": "Scrollable Vertical Stack",
      "alignment": "start",
      "padding": "standard (16px or 20px)",
      "sections": [
        "Header (Profile + Greeting + Theme Toggle)",
        "Portfolio Summary Card (Total Return, Win Rate)",
        "Recent Backtests List (Horizontal Scroll or Vertical List)",
        "Quick Actions Grid (New Backtest, Upload Strategy)",
        "Market Overview (Mini Chart)"
      ]
    },
    "strategy_details": {
      "layout": "Sticky Header + Scrollable Body",
      "sections": [
        "Header (Strategy Name, Status Badge, Edit Button)",
        "Performance Metrics Grid (Sharpe, Sortino, Drawdown)",
        "Equity Curve Chart (Interactive Line Chart)",
        "Trade Log Table (Paginated or Virtualized List)",
        "AI Analysis Section (Collapsible Markdown Card)"
      ]
    }
  },
  "component_library": {
    "Button": {
      "variants": ["primary", "secondary", "ghost", "destructive", "outline"],
      "sizes": ["sm", "md", "lg", "icon"],
      "baseStyle": {
        "borderRadius": "lg",
        "alignItems": "center",
        "justifyContent": "center",
        "flexDirection": "row"
      }
    },
    "Card": {
      "baseStyle": {
        "backgroundColor": "surface",
        "borderRadius": "xl",
        "padding": "4",
        "borderWidth": 1,
        "borderColor": "border"
      }
    },
    "Input": {
      "baseStyle": {
        "height": 48,
        "borderRadius": "lg",
        "borderWidth": 1,
        "borderColor": "input",
        "paddingHorizontal": "3",
        "backgroundColor": "background",
        "color": "foreground"
      }
    },
    "Badge": {
      "baseStyle": {
        "borderRadius": "full",
        "paddingHorizontal": "2.5",
        "paddingVertical": "0.5",
        "alignSelf": "flex-start"
      }
    }
  },
  "charts": {
    "library": "react-native-gifted-charts",
    "equity_curve": {
      "type": "LineChart",
      "props": {
        "thickness": 2,
        "color": "primary",
        "areaChart": true,
        "startFillColor": "primary",
        "startOpacity": 0.2,
        "endOpacity": 0.0,
        "hideRules": true,
        "yAxisThickness": 0,
        "xAxisThickness": 0,
        "hideYAxisText": false,
        "pointerConfig": {
          "pointerStripHeight": 160,
          "pointerStripColor": "mutedForeground",
          "pointerStripWidth": 2,
          "pointerColor": "mutedForeground",
          "radius": 6,
          "pointerLabelWidth": 100,
          "pointerLabelHeight": 90,
          "activatePointersOnLongPress": true,
          "autoAdjustPointerLabelPosition": false
        }
      }
    }
  },
  "icons": {
    "library": "@expo/vector-icons",
    "set": "Lucide",
    "mapping": {
      "backtest": "activity",
      "strategy": "code",
      "upload": "upload-cloud",
      "settings": "settings",
      "home": "home",
      "profile": "user",
      "theme": "sun/moon",
      "chevronRight": "chevron-right",
      "chevronLeft": "chevron-left",
      "close": "x",
      "check": "check",
      "alert": "alert-triangle",
      "info": "info"
    }
  },
  "ai_integration": {
    "format": "markdown",
    "styling": {
      "headings": "font-heading text-lg font-bold mb-2",
      "paragraph": "font-body text-base text-muted-foreground mb-4",
      "list": "pl-4 mb-4",
      "code": "font-mono bg-muted p-1 rounded text-sm"
    }
  },
  "instructions_to_main_agent": [
    "INSTALL: `npx expo install expo-font @expo-google-fonts/manrope @expo-google-fonts/inter @expo-google-fonts/jetbrains-mono`",
    "INSTALL: `npm install react-native-gifted-charts react-native-svg` (peer dependency)",
    "INSTALL: `npm install lucide-react-native` (for consistent icons, or stick to @expo/vector-icons if preferred but Lucide is cleaner)",
    "SETUP: Create a `ThemeContext` to manage dark/light mode toggle and persist preference using `AsyncStorage`.",
    "SETUP: Create a `components/ui` folder for reusable primitive components (Button, Input, Card, Text, View).",
    "STYLE: Use `StyleSheet.create` but map theme values dynamically from the context.",
    "CRITICAL: Do not use inline styles for complex layouts. Define styles in `styles.ts` or at the bottom of the file.",
    "CRITICAL: Ensure `SafeAreaView` is used correctly on all screens (use `react-native-safe-area-context`).",
    "CRITICAL: Handle keyboard avoidance on forms (`KeyboardAvoidingView`)."
  ],
  "UNIVERSAL_GUIDELINES": [
    "Do not use gradients for text.",
    "Use generous padding (min 16px) inside cards.",
    "Ensure touch targets are at least 44x44px.",
    "Use high contrast for text (check WCAG AA).",
    "Prefer 'font-variant: tabular-nums' for financial data if possible (or use Mono font)."
  ]
}